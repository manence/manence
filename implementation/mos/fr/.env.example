# Squelette de variables d'environnement. Jamais de valeur réelle dans ce fichier :
# il est commité, `.env` (gitignored) porte les vraies valeurs.

# Racine de la production (Spec §16/§18 : la production vit au conteneur, hors git).
# Défaut si absent : ../production/ depuis le cœur. Override par machine, jamais commité en dur.
<PROJET>_PRODUCTION_ROOT=

# Clé API du connecteur principal (couche 7)
EXEMPLE_API_KEY=

# Racine d'un système externe branché (Mise en œuvre §6 : variable d'env, pas de chemin en dur)
EXEMPLE_ROOT=

# Identifiant de l'espace de travail (si le connecteur en a besoin)
EXEMPLE_WORKSPACE_ID=
