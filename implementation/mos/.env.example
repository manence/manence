# Environment variable skeleton. Never put a real value in this file:
# it is committed, and `.env` (gitignored) holds the real values.

# Production root (Spec §16/§18: production lives in the container, outside git).
# Default if unset: ../production/ from the core. Override per machine, never hard-committed.
<PROJECT>_PRODUCTION_ROOT=

# API key for the main connector (layer 7)
EXAMPLE_API_KEY=

# Root of a plugged-in external system (Implementation §6: an env variable, not a hard-coded path)
EXAMPLE_ROOT=

# Workspace identifier (if the connector needs one)
EXAMPLE_WORKSPACE_ID=
